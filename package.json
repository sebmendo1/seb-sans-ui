{
  "name": "seb-sans-legibility-survey",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,green \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": ".venv/bin/uvicorn api.main:app --host 0.0.0.0 --port 8787 --reload --no-access-log",
    "build": "tsc -b && vite build",
    "start": "uvicorn api.main:app --host 0.0.0.0 --port ${PORT:-8787}",
    "preview": "npm run build && npm run start",
    "test": "vitest run",
    "test:api": "PYTHONPATH=. .venv/bin/pytest api/tests -q",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "opentype.js": "^2.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/opentype.js": "^1.3.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
